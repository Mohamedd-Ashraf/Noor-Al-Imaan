<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/tasbeeh_widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/tasbeeh_widget_bg_dark"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="8dp">

    <!-- Header: Title + Dhikr name -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tasbeeh_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="سبحة"
            android:textColor="#FF7AD5B0"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:text="" />

        <TextView
            android:id="@+id/tasbeeh_dhikr_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="سُبْحَانَ اللَّهِ"
            android:textColor="#EEE9EEF2"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Center: Tap circle with count -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="4dp"
        android:gravity="center">

        <FrameLayout
            android:id="@+id/tasbeeh_tap_area"
            android:layout_width="130dp"
            android:layout_height="130dp"
            android:layout_gravity="center">

            <!-- Bead ring (33 tasbeeh beads, drawn dynamically) -->
            <ImageView
                android:id="@+id/tasbeeh_bead_ring"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitCenter"
                android:clickable="false"
                android:focusable="false" />

            <!-- Inner filled circle -->
            <ImageView
                android:id="@+id/tasbeeh_inner_circle"
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:layout_gravity="center"
                android:background="@drawable/tasbeeh_widget_inner_dark"
                android:clickable="false"
                android:focusable="false"
                android:scaleType="fitXY"
                android:src="@android:color/transparent" />

            <!-- Count text, centered -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="false"
                android:focusable="false">

                <TextView
                    android:id="@+id/tasbeeh_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="٠"
                    android:textColor="#EEE9EEF2"
                    android:textSize="40sp"
                    android:textStyle="bold"
                    android:clickable="false" />

                <TextView
                    android:id="@+id/tasbeeh_target"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="من ٣٣"
                    android:textColor="#BB7AD5B0"
                    android:textSize="12sp"
                    android:clickable="false" />

                <TextView
                    android:id="@+id/tasbeeh_done_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✓ تم"
                    android:textColor="#FF7AD5B0"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    android:clickable="false" />

                <TextView
                    android:id="@+id/tasbeeh_tap_hint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="اضغط للتسبيح"
                    android:textColor="#557AD5B0"
                    android:textSize="8sp"
                    android:layout_marginTop="3dp"
                    android:clickable="false" />
            </LinearLayout>
        </FrameLayout>
    </FrameLayout>

    <!-- Bottom: Reset + Next Preset + Total -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <FrameLayout
            android:id="@+id/tasbeeh_reset_btn"
            android:layout_width="32dp"
            android:layout_height="28dp"
            android:background="@drawable/tasbeeh_widget_btn_dark">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="↺"
                android:textColor="#EEE9EEF2"
                android:textSize="16sp" />
        </FrameLayout>

        <LinearLayout
            android:id="@+id/tasbeeh_next_btn"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:layout_marginStart="6dp"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:background="@drawable/tasbeeh_widget_btn_dark"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="التالي"
                android:textColor="#EEE9EEF2"
                android:textSize="9sp"
                android:includeFontPadding="false" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="-2dp"
                android:text="←"
                android:textColor="#FF7AD5B0"
                android:textSize="11sp"
                android:textStyle="bold"
                android:includeFontPadding="false" />
        </LinearLayout>

        <TextView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:text="" />

        <TextView
            android:id="@+id/tasbeeh_total_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="الإجمالي:"
            android:textColor="#AAE9EEF2"
            android:textSize="9sp" />

        <TextView
            android:id="@+id/tasbeeh_total"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="3dp"
            android:text="٠"
            android:textColor="#FF7AD5B0"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
